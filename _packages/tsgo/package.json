    "effect-tsgo": "./src/cli.ts"
  },
  "files": [
    "bin/"
  ],
  "optionalDependencies": {
    "@effect/tsgo-win32-x64": "workspace:*",
    "@effect/tsgo-win32-arm64": "workspace:*",
    "@effect/tsgo-linux-x64": "workspace:*",
    "@effect/tsgo-linux-arm64": "workspace:*",
    "@effect/tsgo-linux-arm": "workspace:*",
    "@effect/tsgo-darwin-x64": "workspace:*",
    "@effect/tsgo-darwin-arm64": "workspace:*"
  },
  "devDependencies": {
    "@effect/platform-node": "4.0.0-beta.11",
    "@effect/platform-node-shared": "4.0.0-beta.11",
    "@types/node": "^24.3.0",
    "tsdown": "^0.20.1",
    "typescript": "^5.9.2",
    "effect": "4.0.0-beta.11"
  }
}
