{
  "name": "@effect/tsgo",
  "version": "0.0.1",
  "description": "Effect Language Service for TypeScript-Go — Effect-specific diagnostics and hover features.",
  "license": "MIT",
  "repository": "github:mattiamanzati/effect-typescript-go",
  "bugs": "https://github.com/mattiamanzati/effect-typescript-go/issues",
  "homepage": "https://github.com/mattiamanzati/effect-typescript-go#readme",
  "publishConfig": {
    "access": "public",
    "bin": {
      "effect-tsgo": "./bin/effect-tsgo.js"
    }
  },
  "scripts": {
    "build": "tsdown --config tsdown.config.mjs",
    "check": "tsc --noEmit -p tsconfig.json"
